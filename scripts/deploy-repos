#!/usr/bin/env bash
# Author: PB and cc-dots 🧷
# Date: 2026-05-28
# License: (c) HRDAG, 2026, GPL-2 or newer
#
# dotfiles/scripts/deploy-repos
#
# Per-repo composability deployer. Walks ai/repos.txt; for each target,
# manages a machine-local .claude/lib symlink and/or re-renders the
# repo's composed CLAUDE.md. Idempotent.
#
# Manifest entries are "PATH [MODE]". MODE (default auto-detected):
#   template  — render <repo>/ai/CLAUDE.template.md → <repo>/CLAUDE.md,
#               + .claude/lib symlink. (auto when ai/CLAUDE.template.md exists)
#   inplace   — render <repo>/CLAUDE.md from its embedded manifest, in
#               place; NO symlink (nothing else in the repo is touched).
#   symlink   — .claude/lib symlink only, no render. (auto otherwise)
#
# Usage:
#   deploy-repos                    # render + symlink for all targets
#   deploy-repos --verify-only      # check for drift, exit non-zero if any
#   deploy-repos --filter PATTERN   # only targets whose path matches
#   deploy-repos --refresh-configs  # overwrite drifted cc-dots seed configs with canonical
#   deploy-repos --help

set -euo pipefail

DOTFILES=${DOTFILES:-$HOME/dotfiles}
MANIFEST=${DEPLOY_REPOS_MANIFEST:-$DOTFILES/ai/repos.txt}
USER_MODULES=${CLAUDE_MD_USER_MODULES:-$DOTFILES/ai/modules}
USER_LIB=${USER_LIB:-$HOME/.claude/lib}

# Canonical sources for pre-commit seeding (Track 1a). Seeded into every
# target so lint + the pre-push review nag are consistent across repos.
PRECOMMIT_SRC=$DOTFILES/ai/templates/pre-commit-config.yaml
YAMLLINT_SRC=$DOTFILES/.yamllint
NAG_SRC=$DOTFILES/scripts/pre-push-review-reminder.sh

VERIFY_ONLY=0
FILTER=""
REFRESH_CONFIGS=0

usage() {
    sed -n '2,24p' "$0" | sed 's/^# \{0,1\}//'
}

while [ $# -gt 0 ]; do
    case "$1" in
        --verify-only)     VERIFY_ONLY=1; shift ;;
        --filter)          FILTER=$2; shift 2 ;;
        --refresh-configs) REFRESH_CONFIGS=1; shift ;;
        -h|--help)         usage; exit 0 ;;
        *) echo "unknown flag: $1" >&2; usage >&2; exit 2 ;;
    esac
done

[ -f "$MANIFEST" ] || { echo "deploy-repos: manifest not found: $MANIFEST" >&2; exit 1; }
[ -d "$USER_LIB" ] || { echo "deploy-repos: $USER_LIB does not exist (run install.sh first)" >&2; exit 1; }

any_stale=0
skipped=0

# Seed one canonical artifact into a target: copy if absent. If present and
# drifted, default is to report and LEAVE AS-IS (a repo may have customized
# it) — but --refresh-configs overwrites it with canonical, which is how a
# canonical config CHANGE propagates to already-seeded repos (copy-if-absent
# can't). Informational only; does not affect the --verify-only exit code
# (a customized or not-yet-seeded config is not CLAUDE.md drift).
seed_file() {
    local src=$1 dst=$2 label=$3
    if [ ! -e "$dst" ]; then
        if [ "$VERIFY_ONLY" -eq 1 ]; then
            echo "  precommit: would seed $label (absent)"
        else
            mkdir -p "$(dirname "$dst")"
            cp "$src" "$dst"
            echo "  precommit: seeded $label"
        fi
    elif ! cmp -s "$src" "$dst"; then
        if [ "$VERIFY_ONLY" -eq 1 ]; then
            echo "  precommit: $label differs from canonical$([ "$REFRESH_CONFIGS" -eq 1 ] && echo ' — would refresh' || echo ' — left as-is')"
        elif [ "$REFRESH_CONFIGS" -eq 1 ]; then
            cp "$src" "$dst"
            echo "  precommit: $label REFRESHED to canonical (was drifted)"
        else
            echo "  precommit: $label differs from canonical — left as-is (use --refresh-configs to overwrite)"
        fi
    else
        echo "  precommit: $label ok"
    fi
}

# Seed the pre-commit config + yamllint + review nag into a target, and
# install the git hooks. Runs for every mode (lint is orthogonal to the
# CLAUDE.md render mode).
seed_precommit() {
    local repo=$1
    seed_file "$PRECOMMIT_SRC" "$repo/.pre-commit-config.yaml" ".pre-commit-config.yaml"
    seed_file "$YAMLLINT_SRC"  "$repo/.yamllint"               ".yamllint"
    seed_file "$NAG_SRC"       "$repo/scripts/pre-push-review-reminder.sh" "scripts/pre-push-review-reminder.sh"
    if [ "$VERIFY_ONLY" -eq 0 ] && [ -f "$repo/scripts/pre-push-review-reminder.sh" ]; then
        chmod +x "$repo/scripts/pre-push-review-reminder.sh"
    fi
    if [ "$VERIFY_ONLY" -eq 0 ] && command -v pre-commit >/dev/null 2>&1; then
        if (cd "$repo" && pre-commit install >/dev/null 2>&1 \
                       && pre-commit install --hook-type pre-push >/dev/null 2>&1); then
            echo "  precommit: hooks installed"
        fi
    fi
}

# Read manifest; trim comments + blanks; expand ~/.
while IFS= read -r raw; do
    line=${raw%%#*}
    read -r path mode _ <<<"$line"
    [ -z "${path:-}" ] && continue
    [ -n "$FILTER" ] && [[ "$path" != *"$FILTER"* ]] && continue

    # shellcheck disable=SC2088  # '~/' is a literal case-match pattern, not meant to expand
    case "$path" in
        /*)    repo="$path" ;;
        '~/'*) repo="${HOME}/${path:2}" ;;
        *)     repo="$HOME/$path" ;;
    esac

    if [ ! -d "$repo" ]; then
        echo "  skip: $repo (not present on this machine)"
        skipped=$((skipped + 1))
        continue
    fi

    # Resolve effective mode: explicit wins; else template if a template
    # file exists, else symlink-only.
    if [ -z "${mode:-}" ]; then
        if [ -f "$repo/ai/CLAUDE.template.md" ]; then mode=template; else mode=symlink; fi
    fi

    echo "==> $repo [$mode]"

    # Stage 1: .claude/lib symlink (skipped for in-place repos — they
    # consume only user-wide modules and reference ~/.claude/lib by
    # absolute path, so nothing in the repo needs the symlink)
    if [ "$mode" = inplace ]; then
        echo "  symlink: skipped (in-place mode)"
    else
    cdir="$repo/.claude"
    mkdir -p "$cdir"
    link="$cdir/lib"
    if [ -L "$link" ]; then
        cur=$(readlink "$link")
        if [ "$cur" = "$USER_LIB" ]; then
            echo "  symlink: ok ($link → $cur)"
        else
            if [ "$VERIFY_ONLY" -eq 1 ]; then
                echo "  symlink: STALE ($link → $cur, want $USER_LIB)"
                any_stale=1
            else
                ln -snf "$USER_LIB" "$link"
                echo "  symlink: updated ($link → $USER_LIB)"
            fi
        fi
    elif [ -e "$link" ]; then
        echo "  symlink: ERROR — $link exists and is not a symlink (manual cleanup needed)" >&2
        any_stale=1
    else
        if [ "$VERIFY_ONLY" -eq 1 ]; then
            echo "  symlink: MISSING ($link)"
            any_stale=1
        else
            ln -s "$USER_LIB" "$link"
            echo "  symlink: created ($link → $USER_LIB)"
        fi
    fi
    fi

    # Stage 2: render the composed CLAUDE.md per mode
    case "$mode" in
        template)
            export CLAUDE_MD_MODULES_DIR="$repo/ai/modules:$USER_MODULES"
            if [ "$VERIFY_ONLY" -eq 1 ]; then
                if claude-md check-tree "$repo/ai" --to "$repo" 2>&1; then
                    echo "  render: ok (template, idempotent)"
                else
                    echo "  render: STALE (template)"
                    any_stale=1
                fi
            else
                claude-md render-tree "$repo/ai" --to "$repo"
            fi
            unset CLAUDE_MD_MODULES_DIR
            ;;
        inplace)
            export CLAUDE_MD_MODULES_DIR="$USER_MODULES"
            if [ "$VERIFY_ONLY" -eq 1 ]; then
                if claude-md check "$repo/CLAUDE.md" >/dev/null 2>&1; then
                    echo "  render: ok (in-place, idempotent)"
                else
                    echo "  render: STALE (in-place — run: claude-md render $repo/CLAUDE.md)"
                    any_stale=1
                fi
            else
                claude-md render "$repo/CLAUDE.md" >/dev/null
                echo "  render: ok (in-place)"
            fi
            unset CLAUDE_MD_MODULES_DIR
            ;;
        *)
            echo "  render: skipped (symlink-only)"
            ;;
    esac

    # Stage 3: pre-commit seeding (all modes)
    seed_precommit "$repo"
done < "$MANIFEST"

echo
if [ "$VERIFY_ONLY" -eq 1 ]; then
    if [ "$any_stale" -eq 1 ]; then
        echo "deploy-repos: DRIFT detected (run without --verify-only to fix)" >&2
        exit 1
    fi
    echo "deploy-repos: all targets clean"
else
    echo "deploy-repos: done"
fi
if [ "$skipped" -gt 0 ]; then
    echo "  ($skipped target(s) not present on this machine — expected)"
fi
exit 0
